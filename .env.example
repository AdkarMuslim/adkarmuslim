# لا تضع NODE_ENV في ملفات .env — Next.js يضبطه تلقائياً؛ قيمة خاطئة على Windows قد تكسر Tailwind (خطأ @tailwind في globals.css).
#
# إلزامي في الإنتاج (Vercel): دومينك النهائي — بدون شرطة مائية في النهاية
# يُتجاهل localhost في build الإنتاج لأغراض canonical و OG
NEXT_PUBLIC_SITE_URL=https://www.adkarmuslim.com

# اختياري: Google Analytics 4 (Measurement ID مثل G-XXXXXXXXXX). إن لم تُضف، يُستخدم المعرف الافتراضي في الكود.
# يُحمّل فقط في الإنتاج (build) وليس على localhost.
# NEXT_PUBLIC_GA_ID=G-HKEVSJXW74

# اختياري: معرّف القارئ في Quran API (1–5)
# التوثيق: https://quranapi.pages.dev/getting-started/audio-recitation
# 1 = مشاري راشد العفاسي (افتراضي)
QURANAPI_RECITER_ID=1
